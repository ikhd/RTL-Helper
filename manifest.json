{
  "manifest_version": 3,
  "name": "RTL Helper",
  "version": "1.0.0",
  "description": "RTL and Arabic readability helper for Claude and custom websites.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://claude.ai/*",
    "http://*/*",
    "https://*/*"
  ],
  "icons": {
    "16":  "icon16.png",
    "32":  "icon32.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "RTL Helper",
    "default_icon": {
      "16":  "icon16.png",
      "32":  "icon32.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "http://*/*",
        "https://*/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}